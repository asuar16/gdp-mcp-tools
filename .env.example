# === Identity ===
# USERNAME=your-username  (auto-detected from $USER if not set)

# === Jenkins ===
JENKINS_TOKEN=your-jenkins-api-token
# DEV_JENKINS_URL=https://dev-jenkins.gdp.data.grubhub.com
# PROD_JENKINS_URL=https://jenkins.gdp.data.grubhub.com
# SYNC_JOB_PATH=job/data_platform/job/Tasks/job/prod_dev_sync/job/prod-dev-table-sync
# DEPLOY_JOB_PATH_TEMPLATE=job/experiments/job/Deployments/job/{repo}/job/deploy-{repo}
# STOP_CLUSTER_JOB_PATH=job/data_platform/job/Tasks/job/cluster_operations/job/stop-cluster
# JENKINS_TIMEOUT_SEC=900
# JENKINS_POLL_INTERVAL_SEC=3

# === Azkaban + Flowlogs SSH ===
OKTA_PASSWORD=your-okta-password
# DEV_AZKABAN_URL=http://dev-azkaban-dr.gdp.data.grubhub.com
# PROD_AZKABAN_URL=https://azkaban.gdp.data.grubhub.com

# === CMDash (EMR Dashboard) ===
# DEV_CMDASH_URL=https://dev-cmdash.gdp.data.grubhub.com
# PROD_CMDASH_URL=https://cmdash.gdp.data.grubhub.com

# === VPN ===
# VPN_PORTAL_URL=https://vpn.grubhub.com

# === Spark History Server ===
# SPARK_HS_PORT=18080

# === Trino (Prod) ===
PRESTO_HOST=presto.gdp.data.grubhub.com
PRESTO_PASSWORD=your-trino-password
PRESTO_PORT=443
PRESTO_CATALOG=hive

# === Trino (Dev) ===
# DEV_PRESTO_HOST=dev-presto.gdp.data.grubhub.com

# === Redash ===
REDASH_URL=https://dev-redash.gdp.data.grubhub.com
REDASH_API_KEY=your-redash-api-key

# === Jira ===
JIRA_URL=https://grubhub.atlassian.net
JIRA_USERNAME=your-email@grubhub.com
JIRA_PERSONAL_TOKEN=your-jira-personal-access-token
JIRA_PROJECTS_FILTER=OED

# === Slack ===
# User tokens (posts as your name)
SLACK_MCP_XOXC_TOKEN=your-xoxc-token
SLACK_MCP_XOXD_TOKEN=your-xoxd-token
SLACK_MCP_USER_AGENT=your-browser-user-agent
# Bot token (fallback)
SLACK_TOKEN=your-xoxb-bot-token
SLACK_DEFAULT_CHANNEL=your-slack-channel-id

# === GitHub ===
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_USER=your-github-username

# === DataDog MCP ===
DD_API_KEY=your-datadog-api-key
DD_APP_KEY=your-datadog-app-key
DD_SITE=datadoghq.com

# === PagerDuty MCP ===
PAGERDUTY_USER_API_KEY=your-pagerduty-api-token
PAGERDUTY_API_HOST=https://api.pagerduty.com

# === Google Workspace MCP ===
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
USER_GOOGLE_EMAIL=your-email@grubhub.com